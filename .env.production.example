# FairShareCoin Foundation production config
PORT=4010
NODE_ENV=production
FSC_IDENTITY_VERIFIER=mock
FSC_UI_DEBUG=0
# Suggested prod default: 1800 (30 minutes)
FSC_EMAIL_VERIFICATION_TTL_SEC=300

# Dedicated production DB path
FSC_DB_PATH=/var/lib/fsc/prod/fsc.db

# Optional: public base URL for docs/links
# FSC_BASE_URL=https://fairsharecoin.org
