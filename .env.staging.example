# FairShareCoin Foundation staging config
PORT=4010
NODE_ENV=staging
FSC_IDENTITY_VERIFIER=mock
FSC_UI_DEBUG=0
FSC_EMAIL_VERIFICATION_TTL_SEC=300

# Keep staging DB isolated
FSC_DB_PATH=/var/lib/fsc/staging/fsc.db

# Optional: public base URL for docs/links
# FSC_BASE_URL=https://staging.fairsharecoin.org
